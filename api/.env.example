# REVERIE API Configuration
# Copy to .env and fill in real values

# Debug mode (never true in production)
DEBUG=false

# JWT secret — generate with: openssl rand -hex 32
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# JWT settings
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# Thunderbird MCP API — used for trip/booking queries
THUNDERBIRD_API_URL=https://api.d2mluxury.quest
THUNDERBIRD_API_KEY=

# SMTP — magic link emails via d2mconcierge
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=d2mconcierge@gmail.com
SMTP_PASSWORD=

# Magic link base URL — must match frontend domain
MAGIC_LINK_BASE_URL=https://app.d2mluxury.quest

# CORS origins — comma-separated (parsed as JSON list)
CORS_ORIGINS=["https://app.d2mluxury.quest","http://localhost:5173"]
